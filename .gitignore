# Universal ignores for any project stack.
# Add stack-specific entries in the section at the bottom.

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Claude Code
.claude/settings.local.json

# Local lint config
.markdownlint.jsonc

# Editors / IDEs
.idea/
.vscode/
*.swp
*~
.history/

# Environment & secrets
.env
.env.local
.env.*.local

# Logs & temp
*.log
tmp/
*.bak

# ---------------------------------------------------------------------------
# Stack-specific entries — keep aligned with specs/tech-stack.md.
# ---------------------------------------------------------------------------

# Tauri client app (Rust + OS webview)
target/
src-tauri/target/
src-tauri/gen/

# Frontend tooling for the Tauri webview
node_modules/
dist/
.vite/

# pi-gen image build artifacts (built/flashable images, not committed)
*.img
*.img.xz
*.zip
pi-gen/
deploy/

# Build-time downloads (container .debs, icons, base images)
downloads/

# Sample-app runtime file-manager uploads (keep the dir, not its contents)
appliance/sample-app/data/*
!appliance/sample-app/data/.gitkeep

# pi-gen working clone (Phase 7 build)
.pi-gen/
